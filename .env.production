# AI Manager - Production Environment Configuration
# WARNING: This file contains sensitive information. Never commit to version control.

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=your-super-secret-key-here-change-this-in-production
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://ai_manager:your-postgres-password@postgres:5432/ai_manager_db
POSTGRES_PASSWORD=your-secure-postgres-password-here
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://:your-redis-password@redis:6379/0
REDIS_PASSWORD=your-secure-redis-password-here
CACHE_TTL=3600

# =============================================================================
# AI PROVIDER API KEYS (Store in Secrets Manager in production)
# =============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
OLLAMA_BASE_URL=http://ollama:11434

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# =============================================================================
# FILE STORAGE CONFIGURATION
# =============================================================================
DATA_PATH=/var/lib/ai-manager
UPLOAD_MAX_SIZE=100MB
ARTIFACTS_RETENTION_DAYS=30

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
PROMETHEUS_ENABLED=true
GRAFANA_PASSWORD=your-secure-grafana-password
SENTRY_DSN=https://your-sentry-dsn-here
HEALTH_CHECK_INTERVAL=30

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_S3_BUCKET=ai-manager-backups-prod
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
BACKUP_RETENTION_DAYS=90

# =============================================================================
# EMAIL CONFIGURATION (for notifications)
# =============================================================================
EMAIL_BACKEND=smtp
SMTP_HOST=your-smtp-host.com
SMTP_PORT=587
SMTP_USER=notifications@yourdomain.com
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@yourdomain.com

# =============================================================================
# WORKER CONFIGURATION
# =============================================================================
WORKER_CONCURRENCY=4
WORKER_TIMEOUT=3600
WORKER_MEMORY_LIMIT=4GB
MAX_CONCURRENT_TASKS=10

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# SSL/TLS CONFIGURATION
# =============================================================================
SSL_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/ai-manager.crt
SSL_KEY_PATH=/etc/ssl/private/ai-manager.key

# =============================================================================
# WEBHOOK NOTIFICATIONS
# =============================================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/discord/webhook

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
UVICORN_WORKERS=4
UVICORN_WORKER_CLASS=uvicorn.workers.UvicornWorker
UVICORN_MAX_REQUESTS=10000
UVICORN_MAX_REQUESTS_JITTER=1000