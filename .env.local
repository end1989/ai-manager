# AI Manager - Local Development Configuration

# Application settings
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
SECRET_KEY=local-development-secret-key-for-testing
JWT_SECRET_KEY=local-jwt-secret-for-development

# Database (using SQLite for local development)
DATABASE_URL=sqlite:///./manager.db
DB_POOL_SIZE=5

# Redis (optional for local - will fall back gracefully)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# AI Providers (using mock for local testing)
OPENAI_API_KEY=mock-openai-key
ANTHROPIC_API_KEY=mock-anthropic-key
LLM_PROVIDER=mock

# Worker settings
WORKER_CONCURRENCY=2
WORKER_TIMEOUT=300
MAX_CONCURRENT_TASKS=3

# File storage
UPLOAD_MAX_SIZE=10MB
ARTIFACTS_RETENTION_DAYS=7

# Rate limiting (relaxed for development)
RATE_LIMIT_ENABLED=false

# Monitoring
PROMETHEUS_ENABLED=false
HEALTH_CHECK_INTERVAL=60

# Development features
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1