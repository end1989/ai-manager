# Marks for test categorization
pytest.mark.unit = pytest.mark.unit
pytest.mark.integration = pytest.mark.integration
pytest.mark.slow = pytest.mark.slow
pytest.mark.database = pytest.mark.database
pytest.mark.subprocess = pytest.mark.subprocess
pytest.mark.filesystem = pytest.mark.filesystem


# Custom assertions for better test failures
def assert_task_status(task_queue: TaskQueue, task_id: str, expected_status: str):
    """Assert task has expected status with detailed error message."""
    task_model = task_queue.db.get_task(task_id)
    assert task_model is not None, f"Task {task_id} not found in database"
    assert task_model.status == expected_status, (
        f"Task {task_id} status is '{task_model.status}', expected '{expected_status}'"
    )


def assert_run_artifacts_exist(temp_dir: Path, run_id: str):
    """Assert that run artifacts exist and are valid."""
    run_dir = temp_dir / "runs" / run_id
    
    # Check directory exists
    assert run_dir.exists(), f"Run directory should exist: {run_dir}"
    
    # Check required files
    task_spec_file = run_dir / "task_spec.json"
    worker_report_file = run_dir / "worker_report.json"
    pr_proposal_file = run_dir / "pr_proposal.json"
    
    TestUtilities.assert_json_file_valid(task_spec_file)
    TestUtilities.assert_json_file_valid(worker_report_file)
    TestUtilities.assert_json_file_valid(pr_proposal_file)


# Add custom assertions to pytest namespace
pytest.assert_task_status = assert_task_status
pytest.assert_run_artifacts_exist = assert_run_artifacts_exist


# Pytest configuration
def pytest_configure(config):
    """Configure pytest with custom markers."""
    config.addinivalue_line("markers", "unit: Unit tests")
    config.addinivalue_line("markers", "integration: Integration tests")
    config.addinivalue_line("markers", "slow: Slow tests")
    config.addinivalue_line("markers", "database: Database tests")
    config.addinivalue_line("markers", "subprocess: Subprocess tests") 
    config.addinivalue_line("markers", "filesystem: Filesystem tests")


def pytest_collection_modifyitems(config, items):
    """Automatically mark tests based on their location."""
    for item in items:
        # Mark tests in unit directory as unit tests
        if "unit" in str(item.fspath):
            item.add_marker(pytest.mark.unit)
        
        # Mark tests in integration directory as integration tests
        if "integration" in str(item.fspath):
            item.add_marker(pytest.mark.integration)
        
        # Mark async tests
        if asyncio.iscoroutinefunction(item.function):
            item.add_marker(pytest.mark.asyncio)


# Cleanup after all tests
def pytest_sessionfinish(session, exitstatus):
    """Cleanup after test session."""
    # Clean up any remaining test artifacts
    import tempfile
    temp_dir = Path(tempfile.gettempdir())
    
    for item in temp_dir.glob("tmp*"):
        if item.is_dir():
            try:
                shutil.rmtree(item, ignore_errors=True)
            except Exception:
                pass