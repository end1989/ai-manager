    with tempfile.TemporaryDirectory() as tmp_dir:
        yield Path(tmp_dir)


@pytest.fixture
def test_env(temp_dir):
    """Set up isolated test environment with temporary paths."""
    # Store original environment
    original_env = os.environ.copy()
    
    # Set test environment variables
    test_db_path = temp_dir / "test_manager.db"
    test_env_vars = {
        "MANAGER_DB_URL": f"sqlite:///{test_db_path}",
        "RUNS_DIR": str(temp_dir / "runs"),
        "ARTIFACTS_DIR": str(temp_dir / "artifacts"),
        "LOGS_DIR": str(temp_dir / "logs"),
        "DEV_MODE": "1",
        "LOG_LEVEL": "DEBUG",
        "RUN_TIMEOUT_SECS": "30",  # Shorter timeout for tests
    }
    
    for key, value in test_env_vars.items():
        os.environ[key] = value
    
    # Create test directories
    (temp_dir / "runs").mkdir()
    (temp_dir / "artifacts").mkdir()
    (temp_dir / "logs").mkdir()
    
    yield temp_dir, test_env_vars
    
    # Restore original environment
    os.environ.clear()
    os.environ.update(original_env)


