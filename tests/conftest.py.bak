class TestUtilities:
    """Utility class for common testing operations."""
    
    @staticmethod
    def verify_task_in_db(task_queue: TaskQueue, task_id: str) -> bool:
        """Verify a task exists in the database."""
        task = task_queue.get_task(task_id)
        return task is not None
    
    @staticmethod
    def create_test_run_directory(temp_dir: Path, run_id: str) -> Path:
        """Create a test run directory with basic structure."""
        run_dir = temp_dir / "runs" / run_id
        run_dir.mkdir(parents=True)
        
        # Create subdirectories
        (run_dir / "workdir").mkdir()
        (run_dir / "logs").mkdir()
        (run_dir / "artifacts").mkdir()
        
        return run_dir
    
    @staticmethod
    def assert_file_exists(file_path: Path, message: str = ""):
        """Assert that a file exists with optional message."""
        assert file_path.exists(), f"File should exist: {file_path} {message}"
    
    @staticmethod
    def assert_json_file_valid(file_path: Path):
        """Assert that a JSON file exists and is valid."""
        import json
        
        TestUtilities.assert_file_exists(file_path)
        
        try:
            with open(file_path) as f:
                json.load(f)
        except json.JSONDecodeError as e:
            pytest.fail(f"Invalid JSON in {file_path}: {e}")
    
    @staticmethod
    async def wait_for_condition(condition_func, timeout: float = 5.0, interval: float = 0.1):
        """Wait for a condition to become true."""
        import time
        
        start_time = time.time()
        while time.time() - start_time < timeout:
            if condition_func():
                return True
            await asyncio.sleep(interval)
        
        return False


@pytest.fixture
def test_utils():
    """Provide test utilities."""
    return TestUtilities


