# Database Configuration
MANAGER_DB_URL=sqlite:///./manager.db

# Worker Execution Limits
RUN_CPU_SECS=300
RUN_MEM_MB=512
RUN_TIMEOUT_SECS=1800

# Security Settings
NO_NET=1
WORKER_SANDBOX=1

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Artifacts
MAX_ARTIFACT_SIZE_MB=100
ARTIFACT_RETENTION_DAYS=30

# Development
DEV_MODE=0