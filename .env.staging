# AI Manager - Staging Environment Configuration
# Staging environment for testing production deployments

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
ENVIRONMENT=staging
DEBUG=false
LOG_LEVEL=DEBUG
SECRET_KEY=staging-secret-key-change-this
ALLOWED_HOSTS=staging.yourdomain.com

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://ai_manager_staging:staging-db-password@postgres:5432/ai_manager_staging_db
POSTGRES_PASSWORD=staging-postgres-password
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=15

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://:staging-redis-password@redis:6379/1
REDIS_PASSWORD=staging-redis-password
CACHE_TTL=1800

# =============================================================================
# AI PROVIDER API KEYS (Test keys)
# =============================================================================
OPENAI_API_KEY=sk-test-openai-api-key-staging
ANTHROPIC_API_KEY=sk-ant-test-anthropic-api-key-staging
OLLAMA_BASE_URL=http://ollama:11434

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
JWT_SECRET_KEY=staging-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
CORS_ORIGINS=https://staging.yourdomain.com

# =============================================================================
# FILE STORAGE CONFIGURATION
# =============================================================================
DATA_PATH=/var/lib/ai-manager-staging
UPLOAD_MAX_SIZE=50MB
ARTIFACTS_RETENTION_DAYS=7

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
PROMETHEUS_ENABLED=true
GRAFANA_PASSWORD=staging-grafana-password
SENTRY_DSN=https://staging-sentry-dsn-here
HEALTH_CHECK_INTERVAL=60

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 4 * * *
BACKUP_S3_BUCKET=ai-manager-backups-staging
AWS_ACCESS_KEY_ID=staging-aws-access-key
AWS_SECRET_ACCESS_KEY=staging-aws-secret-key
BACKUP_RETENTION_DAYS=7

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
EMAIL_BACKEND=console
SMTP_HOST=mailhog
SMTP_PORT=1025
EMAIL_FROM=staging@yourdomain.com

# =============================================================================
# WORKER CONFIGURATION
# =============================================================================
WORKER_CONCURRENCY=2
WORKER_TIMEOUT=1800
WORKER_MEMORY_LIMIT=2GB
MAX_CONCURRENT_TASKS=5

# =============================================================================
# RATE LIMITING (More relaxed for testing)
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=60

# =============================================================================
# SSL/TLS CONFIGURATION
# =============================================================================
SSL_ENABLED=false

# =============================================================================
# WEBHOOK NOTIFICATIONS
# =============================================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/staging/slack/webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/staging/discord/webhook

# =============================================================================
# PERFORMANCE TUNING (Reduced for staging)
# =============================================================================
UVICORN_WORKERS=2
UVICORN_WORKER_CLASS=uvicorn.workers.UvicornWorker
UVICORN_MAX_REQUESTS=5000
UVICORN_MAX_REQUESTS_JITTER=500